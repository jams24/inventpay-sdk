{
  "name": "inventpay",
  "version": "1.2.1",
  "description": "Official JavaScript/TypeScript SDK for InventPay Payment API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "payment",
    "crypto",
    "bitcoin",
    "ethereum",
    "litecoin",
    "usdt",
    "payment-gateway",
    "blockchain",
    "cryptocurrency",
    "merchant-payment",
    "inventpay",
    "digital-products",
    "storefront",
    "withdrawal",
    "solana",
    "usdc"
  ],
  "author": "InventPay",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.23",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.0.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
